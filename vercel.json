{
  "buildCommand": "npm install && npm --prefix frontend install && CI=false npm --prefix frontend run build",
  "outputDirectory": "frontend/build",
  "installCommand": "npm install && npm --prefix frontend install",
  "routes": [
    {
      "src": "/uploads/(.*)",
      "dest": "/api/serve-file?filename=$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/((?!api/).*)",
      "dest": "/index.html"
    }
  ]
}
